    "query-string": "^9.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "slugify": "^1.6.6",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^7.0.0",
    "gh-pages": "^6.1.1",
